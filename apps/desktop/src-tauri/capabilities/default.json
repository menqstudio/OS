{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "T-010 deny-by-default capability set for the BroPS main window. Every app IPC command is declared in the app manifest (build.rs); this file grants allow-* explicitly per the Wave-2b risk tiers (docs/design/WAVE_2B_CAPABILITY_APPROVAL_DESIGN.md). Generic decide_approval is DENIED (approve requires renderer-independent native confirmation, T-011); reject_approval is the fail-safe reject path. A command with no allow-* here is uninvokable from this window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "allow-list-projects",
    "allow-create-project",
    "allow-set-project-status",
    "allow-update-project",
    "allow-list-tasks-by-project",
    "allow-list-tasks-by-status",
    "allow-create-task",
    "allow-set-task-status",
    "allow-list-tasks",
    "allow-update-task",
    "allow-list-task-dependencies",
    "allow-add-task-dependency",
    "allow-remove-task-dependency",
    "allow-list-agents",
    "allow-list-approvals",
    "deny-decide-approval",
    "allow-reject-approval",
    "allow-list-notifications",
    "allow-mark-notification-read",
    "allow-list-decisions",
    "allow-create-decision",
    "allow-list-activity",
    "allow-list-conversations",
    "allow-create-conversation",
    "allow-list-messages",
    "allow-post-message",
    "allow-post-user-message",
    "allow-save-ask-to-chat",
    "allow-delete-conversation",
    "allow-rename-conversation",
    "allow-list-knowledge",
    "allow-search-knowledge",
    "allow-create-knowledge",
    "allow-delete-knowledge",
    "allow-list-memory",
    "allow-create-memory",
    "allow-set-memory-pinned",
    "allow-delete-memory",
    "allow-list-runs",
    "allow-create-run",
    "allow-set-run-status",
    "allow-list-run-steps",
    "allow-add-run-step",
    "allow-set-run-step-status",
    "allow-advance-run",
    "allow-list-events",
    "allow-create-event",
    "allow-delete-event",
    "allow-list-automations",
    "allow-create-automation",
    "allow-set-automation-enabled",
    "allow-delete-automation",
    "allow-list-integrations",
    "allow-set-integration-status",
    "allow-search-all",
    "allow-get-analytics",
    "allow-get-security-summary",
    "allow-ai-status",
    "allow-reply-in-conversation",
    "allow-stream-reply",
    "allow-stream-ask",
    "allow-stream-run-step",
    "allow-list-dir",
    "allow-read-file",
    "allow-write-file"
  ]
}
