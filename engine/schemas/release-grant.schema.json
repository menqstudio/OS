{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://bro.local/schemas/release-grant.schema.json","title":"Bro Release Grant V3","type":"object","additionalProperties":false,"required":["payload","signature"],"properties":{"payload":{"type":"object","additionalProperties":false,"required":["schema","artifact_type","key_id","grant_id","nonce","principal_id","task_id","task_contract_sha256","completion_manifest_sha256","verifier_receipt_sha256","repository","remote","branch","expected_head_sha","expected_tree_identity","allowed_action","issued_at_epoch","expires_at_epoch"],"properties":{"schema":{"const":3},"artifact_type":{"const":"release-grant"},"key_id":{"type":"string","minLength":1},"grant_id":{"type":"string","minLength":2,"maxLength":128},"nonce":{"type":"string","pattern":"^[A-Za-z0-9._-]{16,128}$"},"principal_id":{"const":"owner-gev"},"task_id":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{1,127}$"},"task_contract_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"completion_manifest_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"verifier_receipt_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"repository":{"type":"string","minLength":3},"remote":{"type":"string","minLength":3},"branch":{"type":"string","minLength":1},"expected_head_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"expected_tree_identity":{"type":"string","pattern":"^[0-9a-f]{64}$"},"allowed_action":{"const":"git-push"},"issued_at_epoch":{"type":"integer","minimum":0},"expires_at_epoch":{"type":"integer","minimum":0}}},"signature":{"type":"string","pattern":"^[0-9a-f]{128}$"}}}