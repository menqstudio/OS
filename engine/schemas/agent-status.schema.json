{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/menqstudio/Bro/schemas/agent-status.schema.json",
  "title": "Bro Agent Status Event",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "event_id", "agent_id", "task_id", "status", "observed_at_epoch", "source", "evidence_paths"],
  "properties": {
    "schema": {"const": 1},
    "event_id": {"type": "string", "minLength": 1},
    "agent_id": {"type": "string", "pattern": "^agt-p[0-9]{2,}-r[0-9]{2,}$"},
    "task_id": {"type": ["string", "null"]},
    "status": {"enum": ["idle", "running", "blocked", "waiting-approval", "verification", "failed", "completed"]},
    "observed_at_epoch": {"type": "integer", "minimum": 0},
    "source": {"type": "string", "minLength": 1},
    "evidence_paths": {"type": "array", "uniqueItems": true, "items": {"type": "string"}}
  }
}
