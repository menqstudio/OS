{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/menqstudio/Bro/schemas/task-contract.schema.json",
  "title": "Bro Task Contract",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema", "task_id", "title", "objective", "mode", "risk", "pack_id", "agent_id",
    "assignee_role", "scope", "prohibited_scope", "inputs", "core_skills", "additional_skills",
    "reference_skills", "done_criteria", "verification", "rollback", "repository"
  ],
  "properties": {
    "schema": {"const": 1},
    "task_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "title": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "mode": {"enum": ["review", "work", "release"]},
    "risk": {"enum": ["low", "medium", "high", "critical"]},
    "pack_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "agent_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "assignee_role": {"type": "string", "minLength": 1},
    "scope": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/repoPath"}},
    "prohibited_scope": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/repoPath"}},
    "inputs": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/repoPath"}},
    "core_skills": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "additional_skills": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "reference_skills": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/id"}},
    "done_criteria": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "verifier_agent_id", "verifier_role", "commands"],
      "properties": {
        "required": {"type": "boolean"},
        "verifier_agent_id": {"type": ["string", "null"], "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
        "verifier_role": {"type": ["string", "null"]},
        "commands": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "commands"],
      "properties": {
        "strategy": {"type": "string", "minLength": 1},
        "commands": {"type": "array", "items": {"type": "string", "minLength": 1}}
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["full_name", "branch", "worktree", "base_commit", "tree_identity"],
      "properties": {
        "full_name": {"type": "string", "minLength": 3},
        "branch": {"type": "string", "minLength": 1},
        "worktree": {"type": "string", "minLength": 1},
        "base_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "tree_identity": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  },
  "$defs": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "repoPath": {"type": "string", "minLength": 1, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))(?![A-Za-z]:)[^\\\\]+$"}
  }
}
