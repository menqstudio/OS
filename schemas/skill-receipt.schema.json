{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/menqstudio/Bro/schemas/skill-receipt.schema.json",
  "title": "Bro Skill Load Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "receipt_id", "task_id", "agent_id", "contract_sha256", "repository_commit", "tree_identity", "loaded_at_epoch", "expires_at_epoch", "skills"],
  "properties": {
    "schema": {"const": 1},
    "receipt_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "task_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "agent_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "repository_commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tree_identity": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "loaded_at_epoch": {"type": "integer", "minimum": 0},
    "expires_at_epoch": {"type": "integer", "minimum": 1},
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "kind", "path", "sha256"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
          "kind": {"enum": ["core", "additional", "reference"]},
          "path": {"type": "string", "pattern": "^skills/[a-z0-9][a-z0-9._-]{1,127}/SKILL\\.md$"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
        }
      }
    }
  }
}
