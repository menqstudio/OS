{"$schema":"https://json-schema.org/draft/2020-12/schema","type":"object","additionalProperties":false,"required":["payload","signature"],"properties":{"payload":{"type":"object","additionalProperties":false,"required":["schema","artifact_type","key_id","grant_id","nonce","session_id","agent_id","role","mode","task_contract_sha256","agent_profile_sha256","skill_receipt_sha256","repository","branch","head_sha","tree_identity","issued_at_epoch","expires_at_epoch"],"properties":{"schema":{"const":1},"artifact_type":{"const":"mode-grant"},"key_id":{"type":"string","minLength":1},"grant_id":{"type":"string","pattern":"^[a-z0-9][a-z0-9._-]{1,127}$"},"nonce":{"type":"string","minLength":16,"maxLength":128},"session_id":{"type":"string","minLength":1,"maxLength":256},"agent_id":{"type":"string","pattern":"^agt-p[0-9]{2,}-r[0-9]{2,}$"},"role":{"type":"string","minLength":1,"maxLength":128,"pattern":"^[A-Za-z0-9][A-Za-z0-9 ._&-]{0,127}$"},"mode":{"enum":["work","release"]},"task_contract_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"agent_profile_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"skill_receipt_sha256":{"type":"string","pattern":"^[0-9a-f]{64}$"},"repository":{"type":"string"},"branch":{"type":"string"},"head_sha":{"type":"string","pattern":"^[0-9a-f]{40}$"},"tree_identity":{"type":"string","pattern":"^[0-9a-f]{64}$"},"issued_at_epoch":{"type":"integer"},"expires_at_epoch":{"type":"integer"}}},"signature":{"type":"string","pattern":"^[0-9a-f]{128}$"}}}
