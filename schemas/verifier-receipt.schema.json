{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bro.local/schemas/verifier-receipt.schema.json",
  "title": "Bro Verifier Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema","receipt_id","task_id","builder_agent_id","verifier_agent_id","verifier_role","independence_level","task_contract_sha256","completion_manifest_sha256","candidate_head","candidate_tree","evidence_event_ids","verdict","issued_at_epoch","expires_at_epoch"],
  "properties": {
    "schema": {"const": 1},
    "receipt_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "task_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "builder_agent_id": {"type": "string", "pattern": "^agt-p[0-9]{2,}-r[0-9]{2,}$"},
    "verifier_agent_id": {"type": "string", "pattern": "^agt-p[0-9]{2,}-r[0-9]{2,}$"},
    "verifier_role": {"type": "string", "minLength": 1},
    "independence_level": {"enum": ["L1","L2","L3","L4","L5"]},
    "task_contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "completion_manifest_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "candidate_tree": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "verdict": {"const": "GREEN"},
    "issued_at_epoch": {"type": "integer", "minimum": 0},
    "expires_at_epoch": {"type": "integer", "minimum": 0}
  }
}