{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/menqstudio/Bro/schemas/agent-profile.schema.json",
  "title": "Bro Specialist Agent Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "agent_id",
    "pack_id",
    "role",
    "core_skills",
    "allowed_modes",
    "can_verify",
    "can_push"
  ],
  "properties": {
    "schema": {"const": 1},
    "agent_id": {"type": "string", "pattern": "^agt-p[0-9]{2,}-r[0-9]{2,}$"},
    "pack_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "role": {"type": "string", "minLength": 1},
    "core_skills": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"}},
    "allowed_modes": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["review", "work", "release"]}},
    "can_verify": {"type": "boolean"},
    "can_push": {"type": "boolean"}
  }
}
