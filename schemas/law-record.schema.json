{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OLTS Operating Law Traceability Record (declared facts only)",
  "description": "Declared traceability record for one canonical Operating Law. Proof Level, effective_proof_level and enforcement_status are DERIVED by the validator and MUST NOT appear here (Derivability Principle MP-12).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id", "responsibility", "policy_source", "execution_surfaces",
    "tests", "evidence", "failure_behavior", "owner", "revisions", "runtime_prerequisites"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^L[0-9]{1,3}$"},
    "name": {"type": "string"},
    "responsibility": {"type": "string", "minLength": 8},
    "policy_source": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "execution_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["module", "symbol", "kind", "path_role"],
        "properties": {
          "module": {"type": "string"},
          "symbol": {"type": "string"},
          "kind": {"enum": ["runtime", "startup", "hook", "validator", "recorder", "signer", "verifier", "scheduler", "build", "release", "recovery"]},
          "path_role": {"enum": ["primary", "defense_in_depth", "build_time"]}
        }
      }
    },
    "tests": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "case", "kind"],
        "properties": {
          "file": {"type": "string"},
          "case": {"type": "string"},
          "kind": {"enum": ["allow", "deny"]}
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "writer", "verifier", "retention", "integrity_level", "trust_source"],
      "properties": {
        "schema": {"type": "string"},
        "writer": {"type": "string"},
        "verifier": {"type": "string"},
        "retention": {"enum": ["ephemeral", "session", "task", "retained"]},
        "integrity_level": {"enum": ["Unsigned", "Signed", "Hash-Chained"]},
        "trust_source": {"enum": ["Self", "Independent", "Owner", "External"]}
      }
    },
    "failure_behavior": {
      "type": "object",
      "additionalProperties": false,
      "required": ["class", "mode", "normative_strength"],
      "properties": {
        "class": {"enum": ["NORMATIVE_ENFORCEMENT", "RECOVERY_SELF_HEAL", "ADVISORY_OBSERVATION"]},
        "mode": {"enum": ["fail-closed", "self-heal", "advisory"]},
        "normative_strength": {"enum": ["MUST", "MUST_NOT", "SHALL", "SHOULD", "MAY"]}
      }
    },
    "owner": {"type": "string"},
    "revisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ver", "type", "date", "note"],
        "properties": {
          "ver": {"type": "string"},
          "type": {"enum": ["Editorial", "Behavioral"]},
          "date": {"type": "string"},
          "note": {"type": "string"}
        }
      }
    },
    "runtime_prerequisites": {"type": "array", "items": {"type": "string"}}
  }
}
