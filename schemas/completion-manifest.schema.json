{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bro.local/schemas/completion-manifest.schema.json",
  "title": "Bro Completion Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema","task_id","agent_id","task_contract_sha256","candidate_head","candidate_tree","done_criteria","tests","evidence_event_ids","open_risks","rollback_ready","issued_at_epoch"],
  "properties": {
    "schema": {"const": 1},
    "task_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "agent_id": {"type": "string", "pattern": "^agt-p[0-9]{2,}-r[0-9]{2,}$"},
    "task_contract_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "candidate_head": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "candidate_tree": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "done_criteria": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["criterion","status","evidence_event_ids"], "properties": {"criterion": {"type": "string", "minLength": 1}, "status": {"const": "satisfied"}, "evidence_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}}}},
    "tests": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["command","status","evidence_event_id"], "properties": {"command": {"type": "string", "minLength": 1}, "status": {"const": "passed"}, "evidence_event_id": {"type": "string", "minLength": 1}}}},
    "evidence_event_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "open_risks": {"type": "array", "items": {"type": "string"}},
    "rollback_ready": {"const": true},
    "issued_at_epoch": {"type": "integer", "minimum": 0}
  }
}