{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bro.local/schemas/execution-lease.schema.json",
  "title": "Bro Execution Lease",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "artifact_type",
    "key_id",
    "lease_id",
    "nonce",
    "task_id",
    "agent_id",
    "session_id",
    "repository",
    "branch",
    "worktree",
    "head_sha",
    "tree_identity",
    "allowed_capabilities",
    "issued_at_epoch",
    "expires_at_epoch",
    "max_tool_calls"
  ],
  "properties": {
    "schema": {"const": 1},
    "artifact_type": {"const": "execution-lease"},
    "key_id": {"type": "string", "minLength": 1},
    "lease_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "nonce": {"type": "string", "pattern": "^[A-Za-z0-9._-]{16,128}$"},
    "task_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{1,127}$"},
    "agent_id": {"type": "string", "pattern": "^agt-p[0-9]{2,}-r[0-9]{2,}$"},
    "session_id": {"type": "string", "minLength": 1, "maxLength": 256},
    "repository": {"type": "string", "minLength": 1},
    "branch": {"type": "string", "minLength": 1},
    "worktree": {"type": "string", "minLength": 1},
    "head_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "tree_identity": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "allowed_capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "enum": [
          "WRITE_REPOSITORY",
          "WRITE_FILESYSTEM",
          "WRITE_EXTERNAL",
          "EXECUTE_CODE",
          "USE_NETWORK",
          "USE_CREDENTIAL",
          "SEND_COMMUNICATION",
          "PUBLISH",
          "SPEND",
          "CHANGE_ACCESS",
          "DELETE",
          "DESTRUCTIVE"
        ]
      }
    },
    "issued_at_epoch": {"type": "integer", "minimum": 0},
    "expires_at_epoch": {"type": "integer", "minimum": 0},
    "max_tool_calls": {"type": "integer", "minimum": 1, "maximum": 100000}
  }
}
